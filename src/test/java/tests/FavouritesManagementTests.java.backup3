	@Test(priority = 412, retryAnalyzer = RetryAnalyzer.class, description = "TC_412: Verify cancel button behavior")
	public void verifyCancelAction() {
		String bookTitle = ConfigReader.getProperty("search.keyword", "Book");

		System.out.println("========================================");
		System.out.println("TC_412: Cancel Action Test");
		System.out.println("========================================");

		// Add books and enter selection mode
		navigateToHomePage();
		favourites.addBookToFavourites(bookTitle);

		navigateToFavouritesPage();

		// Select a book
		favourites.selectBookByIndex(0);

		// Click cancel to exit selection mode
		favourites.clickCancel();

		// Verify selection mode is exited (no checkboxes selected)
		int selectedCountAfter = favourites.getSelectedBooksCount();

		System.out.println("Selected Count After Cancel: " + selectedCountAfter);
		System.out.println("========================================");
		System.out.println("Verification: Should exit selection mode");
		System.out.println("========================================");

		Assert.assertTrue(selectedCountAfter == 0,
				"TC_412: Should exit selection mode");

		LOGGER.info("TC_412: ✅ Cancel action working correctly");
		LOGGER.info("TC_412: Expected Result: Exit selection mode. System behaved as expected.");

		System.out.println("TC_412: ✅ Exit selection mode. System behaved as expected with no deviations.");
		System.out.println("========================================");
	}

	// ================= DUPLICATE PREVENTION TESTS =================

	@Test(priority = 414, retryAnalyzer = RetryAnalyzer.class, description = "TC_414: Verify same book not added twice")
	public void verifyDuplicateAddPrevention() {
		String bookTitle = ConfigReader.getProperty("search.resultCountKeyword", "New-3");

		System.out.println("========================================");
		System.out.println("TC_414: Duplicate Add Prevention Test");
		System.out.println("========================================");
		System.out.println("Book Title: " + bookTitle);

		// Add book to favourites
		navigateToHomePage();
		favourites.addBookToFavourites(bookTitle);

		// Try to add the same book again
		favourites.addBookToFavourites(bookTitle);

		// Navigate to favourites and check count (should be 1)
		navigateToFavouritesPage();

		int favouriteBooksCount = favourites.getFavouriteBooksCount();

		System.out.println("Favourite Books Count: " + favouriteBooksCount);
		System.out.println("========================================");
		System.out.println("Verification: No duplicate entries should exist");
		System.out.println("========================================");

		// Count occurrences of the book title
		int bookOccurrences = 0;
		var books = favourites.getFavouriteBooks();
		for (var book : books) {
			if (book.getText().contains(bookTitle)) {
				bookOccurrences++;
			}
		}

		Assert.assertTrue(bookOccurrences <= 1,
				"TC_414: No duplicate entries should exist");

		LOGGER.info("TC_414: ✅ Duplicate prevention working correctly");
		LOGGER.info("TC_414: Expected Result: No duplicate entries. System behaved as expected.");

		System.out.println("TC_414: ✅ No duplicate entries. System behaved as expected with no deviations.");
		System.out.println("========================================");
	}

	// ================= GUEST USER RESTRICTION TESTS =================

	@Test(priority = 415, retryAnalyzer = RetryAnalyzer.class, description = "TC_415: Verify guest restriction")
	public void verifyGuestCannotAddFavourites() {
		// Do NOT login for this test

		System.out.println("========================================");
		System.out.println("TC_415: Guest User Restriction Test");
		System.out.println("========================================");

		// Try to add a book to favourites without logging in
		navigateToHomePage();
		String bookTitle = ConfigReader.getProperty("search.resultCountKeyword", "New-3");

		favourites.addBookToFavourites(bookTitle);

		// Check if redirected to login page
		String currentUrl = driver.getCurrentUrl().toLowerCase();

		System.out.println("Current URL: " + currentUrl);
		System.out.println("========================================");
		System.out.println("Verification: Guest should be redirected to login");
		System.out.println("========================================");

		Assert.assertTrue(currentUrl.contains("login") || currentUrl.contains("signin"),
				"TC_415: Guest should be redirected to login page");

		LOGGER.info("TC_415: ✅ Guest restriction working correctly");
		LOGGER.info("TC_415: Expected Result: Redirect to login. System behaved as expected.");

		System.out.println("TC_415: ✅ Redirect to login. System behaved as expected with no deviations.");
		System.out.println("========================================");
	}


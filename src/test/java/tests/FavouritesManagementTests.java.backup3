			favourites.addBookToFavourites(bookTitle + "_" + i);
		}

		// Navigate to favourites
		navigateToFavouritesPage();

		int favouriteBooksCount = favourites.getFavouriteBooksCount();

		// Test scrolling by checking if page can scroll

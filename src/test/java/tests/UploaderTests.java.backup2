		navigateToUploadPage();

		Assert.assertTrue(upload.getSuccessMessage().contains("success") || upload.getSuccessMessage().isEmpty(),
				"TC_525: File should be cleaned up or preserved correctly after cancel");
		LOGGER.info("TC_525: File upload cleanup verified");
	}

